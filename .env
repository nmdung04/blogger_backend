# Copy this file to .env and fill in real values

PORT=4000
# For MongoDB Atlas (cloud)
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/blogger?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://nmdung04:nmdung04%40@nmd.1sv3agk.mongodb.net/?appName=NMD
JWT_SECRET=your-strong-secret
JWT_EXPIRES_IN=7d

# Optional: allow CORS from these origins (comma separated)
CORS_ORIGINS=http://localhost:3000

# Optional initial admin account (created automatically if not present)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# AI chat
AI_CHAT_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=1.0
AI_SYSTEM_PROMPT=You are a helpful assistant. Answer clearly, accurately, and concisely.
AI_MAX_COMPLETION_TOKENS=1500
AI_MAX_PROMPT_TOKENS=8000
AI_CONTEXT_MESSAGE_LIMIT=20
AI_MAX_MESSAGE_CHARS=8000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_MAX_REQUESTS_PER_WINDOW=10
AI_MAX_CONCURRENT_STREAMS_PER_CLIENT=1
AI_INPUT_COST_PER_1K_TOKENS=0
AI_OUTPUT_COST_PER_1K_TOKENS=0
